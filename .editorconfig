root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[*.{yaml,yml,json,jsonl,md,txt,toml,ini,cfg,conf}]
indent_size = 2

[*.sh]
indent_size = 2

[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 2

[*.bat]
end_of_line = crlf

[*.cmd]
end_of_line = crlf

[*.ps1]
end_of_line = crlf